      "description": "Search + pre-extracted content - best for LLM grounding"
    },
    {
      "name": "web-search",
      "source": "./skills/web-search",
      "description": "Standard web search with snippets and URLs"
    },
    {
      "name": "deep-research",
      "source": "./skills/deep-research",
      "description": "Multi-iteration research for complex topics"
    },
    {
      "name": "images-search",
      "source": "./skills/images-search",
      "description": "Image search with dimensions and metadata"
    },
    {
      "name": "news-search",
      "source": "./skills/news-search",
      "description": "News articles with freshness filtering"
    },
    {
      "name": "videos-search",
      "source": "./skills/videos-search",
      "description": "Video search with duration and view counts"
    },
    {
      "name": "summarizer",
      "source": "./skills/summarizer",
      "description": "AI-powered search summaries with citations"
    },
    {
      "name": "suggest",
      "source": "./skills/suggest",
      "description": "Query autocomplete suggestions"
    },
    {
      "name": "spellcheck",
      "source": "./skills/spellcheck",
      "description": "Spell correction before search"
    },
    {
      "name": "local-pois",
      "source": "./skills/local-pois",
      "description": "Local business and POI details"
    },
    {
      "name": "local-descriptions",
      "source": "./skills/local-descriptions",
      "description": "POI text descriptions"
    },
    {
      "name": "url-submit",
      "source": "./skills/url-submit",
      "description": "Submit URLs to Brave's index"
    },
    {
      "name": "content",
      "source": "./skills/content",
      "description": "Extract page content from URLs"
    }
  ]
